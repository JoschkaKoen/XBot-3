# ── Language Pair ─────────────────────────────────────────────────────────────
# Set these two values to configure the bot for any language pair.
# Everything else (language codes, flag emojis, flag colors, trends country)
# is derived automatically by AI on first run and cached in data/language_config.json.
SOURCE_LANGUAGE=German
TARGET_LANGUAGE=English


# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=grok


# ── Tweet Content ─────────────────────────────────────────────────────────────
# Tweet style: "funny" (ironic/humorous tone) or "normal" (warm, neutral tone)
# Comma-separated pattern cycles deterministically across tweets, e.g.:
#   TWEET_STYLE=funny,normal,normal → tweet 1 funny, 2 normal, 3 normal, 4 funny, …
TWEET_STYLE=funny, normal

# Maximum character length (280 for standard accounts, up to 25000 for Premium)
MAX_TWEET_LENGTH=500

# Maximum number of words in the source-language example sentence
MAX_EXAMPLE_WORDS=9


# ── Word & Trend Selection ────────────────────────────────────────────────────
# Comma-separated cycle (same step index as TWEET_STYLE / IMAGE_STYLE):
#   trends  — word from X trending topics (needs TRENDS_COUNTRY); true/yes/on = same as trends
#   pool    — AI word + random curated theme (German→English only; see data/themes_german_for_english_learners.json)
#   false   — AI word + strategy next_topic/style; off/no/strategy = same as false
# Example: trends,trends,pool,pool,trends
USE_TRENDS=pool, pool, trends, pool, pool, strategy, pool 

# How many of the AI's top-ranked trend word candidates to try before
# falling back to pure AI word selection (e.g. 5 = give up after the top 5 are all already used).
TREND_CANDIDATE_LIMIT=2

# Rotate CEFR levels across cycles: A1 → A2 → B1 → B2 → C1 → C2 → A1 → …
# The last level used is read from post_history; the next one is forced for the
# current cycle (overrides both the word-pick prompt and the tweet prompt).
# true = on | false = off
CEFR_ROTATION=true

# How many recent posts to analyse for strategy updates
ANALYZE_LAST_N=10

# Refresh metrics for the N most-recent tweets at the start of every cycle.
# Deleted tweets are pruned from history. Never triggers a strategy update.
# Set to 0 to disable.
METRICS_FETCH_PER_CYCLE=3

# Max tweets to fetch fresh X metrics for per refresh (X API calls). Default is
# max(ANALYZE_LAST_N, 30) if unset. Use 0 or all = no cap (entire post_history).
# METRICS_FETCH_MAX_TWEETS=30


# ── Image Generation ──────────────────────────────────────────────────────────
# Style: "photographic" (realistic editorial) or "disney" (cute 3D Pixar/Disney CGI)
# Comma-separated pattern cycles deterministically across tweets, e.g.:
#   IMAGE_STYLE=photographic,disney,disney → tweet 1 photographic, 2 disney, 3 disney, 4 photographic, …
IMAGE_STYLE=photographic, disney

# Provider: "midjourney" (requires TT_API_KEY) | "grok" (requires XAI_API_KEY)
#           "z-image-turbo" (ComfyUI local, 8 steps, fast)
#           "z-image-base"  (diffusers local, 20-50 steps, higher quality, no ComfyUI needed)
IMAGE_PROVIDER=z-image-turbo

# Number of images to generate per cycle.
# Used by IMAGE_PROVIDER=grok (parallel) and z-image-turbo (sequential runs with different seeds).
# All candidates are ranked by ImageReward and the best one is picked.
GENERATED_IMAGE_COUNT=4

# Generate an individual AI image prompt for each image (true) or reuse one shared
# prompt for all images (false).
# true  → LLM called N times; each image gets its own unique prompt variation;
#          best image is picked by scoring it against its own prompt.
# false → LLM called once; all images share the same prompt (default, cheaper).
INDIVIDUAL_IMAGE_PROMPTS=true

# ── Z-Image-Turbo settings (IMAGE_PROVIDER=z-image-turbo) ───────────────────
# Denoising steps. Recommended: 8-9. CFG/sampler/scheduler are locked by the model card.
Z_IMAGE_TURBO_STEPS=9

# Output resolution (width × height). Use multiples of 8.
# 1920×1080 = Full HD 16:9 — solid quality with moderate VRAM vs 4K.
# If you turn Wan2.1 video back on, set 832×480 so I2V matches the pipeline.
# Other options: 3840×2160 (4K), 2560×1440 (1440p), 1344×768.
Z_IMAGE_TURBO_WIDTH=1920
Z_IMAGE_TURBO_HEIGHT=1080

# ── Z-Image Base settings (IMAGE_PROVIDER=z-image-base) ─────────────────────
# HuggingFace model ID (auto-downloaded on first use, ~12 GB).
Z_IMAGE_BASE_MODEL_ID=Tongyi-MAI/Z-Image

# Denoising steps (20–50). 30 is a good balance; push to 40-50 for maximum quality.
Z_IMAGE_BASE_STEPS=30

# CFG / guidance scale. 3.5–7.0 works well; higher = stronger prompt adherence.
Z_IMAGE_BASE_GUIDANCE_SCALE=5.0

# Output resolution — keep at 832×480 to match Wan2.1 480p I2V input exactly.
Z_IMAGE_BASE_WIDTH=832
Z_IMAGE_BASE_HEIGHT=480

# Optional negative prompt (base model supports full CFG, unlike turbo).
# Leave blank to use none. Example: "blurry, low quality, watermark, text"
Z_IMAGE_BASE_NEGATIVE_PROMPT=blurry, low quality, watermark, text, logo, ugly, deformed, noisy, grainy

# ── Shared Z-Image prompt suffix (applies to both turbo and base) ────────────
# Quality + anatomy hints appended after the LLM output. Keep it one line; leave blank to disable.
Z_IMAGE_PROMPT_SUFFIX=sharp focus, cinematic lighting, rich colours, professional photography, anatomically correct proportions, two hands per visible person, natural relaxed hand poses, no extra or duplicated limbs

# InstructIR: optional post-enhancement on each Z-Image-Turbo image before ImageReward.
# Requires a clone of https://github.com/mv-lab/InstructIR and its Python deps
# (e.g. pip install -r requirements_gradio.txt inside that repo's venv, or align versions).
# Checkpoints: auto-download to INSTRUCTIR_DIR on first use if huggingface-hub is installed,
# or copy im_instructir-7d.pt and lm_instructir-7d.pt from Hugging Face (marcosv/InstructIR).
# Increases peak GPU memory in this process (ImageReward + InstructIR). ComfyUI is separate.
ENABLE_INSTRUCTIR_ENHANCE=true
# Absolute path to the InstructIR repository root (must contain configs/eval5d.yml).
INSTRUCTIR_DIR=/home/y/Programming/InstructIR
# Optional: override the restoration instruction (long default is set in config.py if unset).
INSTRUCTIR_PROMPT=sharpen this image and remove any softness or blur, reduce noise, boost contrast and colour vibrancy, make it look crisp, vivid and professionally retouched

# Overlay a source→target flag badge on the top-right corner of each image
FLAG_OVERLAY=true


# ── Video Generation ──────────────────────────────────────────────────────────
# Mix TTS with background music (Background Music/music.mp3): on | off (or true/false)
ENABLE_BACKGROUND_MUSIC=off

# Video overlay style: "ktv" (karaoke-style word highlight) or "simple"
VIDEO_STYLE=ktv

# Interpolate video to a higher FPS before upload using Practical-RIFE.
# true  → run RIFE after create_video, before publish (adds ~1-2 min per video).
# false → skip interpolation, upload at WAN_VIDEO_FPS as-is.
VIDEO_INTERPOLATION=true

# Absolute path to your Practical-RIFE clone.
# Setup is complete — repo cloned, model weights in train_log/, skvideo installed.
RIFE_DIR=/home/y/Programming/Practical-RIFE

# Python interpreter used to run RIFE's inference_video.py.
# Must have PyTorch with CUDA support for the installed GPU.
# Wan2GP's venv is used here because it has PyTorch 2.10+cu130 (RTX 5070 Blackwell support).
RIFE_PYTHON=/home/y/Programming/Wan2GP/venv/bin/python

# Target FPS after RIFE interpolation.
# 32 = exact 2x from 16fps source (--exp4
# KTV subtitle font size in px at 720p (standard HD — what you see on a Grok video).
# Other resolutions scale proportionally (e.g. 80 → ~53px on 480p Wan).
# Range 12–200. Default 80.
KTV_FONT_SIZE=80

# Video engine for animating the generated image before KTV overlay:
#   "off"    → no animation; static KTV or Ken Burns only (default)
#   "grok"   → Grok Imagine API  (requires XAI_API_KEY, ~15 s, 720p)
#   "WAN2.1" → local Wan2.1 model via Wan2GP  (requires WAN_VIDEO_DIR, ~7 min, 480p)
ENABLE_VIDEO=off

# Path to the Wan2GP installation directory (only used when ENABLE_VIDEO=WAN2.1).
WAN_VIDEO_DIR=/home/y/Programming/Wan2GP

# Apply a slow Ken Burns zoom+pan to the still image (used when ENABLE_VIDEO=off
# or when the video frequency gate skips this cycle). PIL AFFINE, sub-pixel smooth.
ENABLE_KEN_BURNS=false

# Generate a video every Nth tweet (1 = every tweet, 2 = every 2nd, etc.)
# Applies to both "grok" and "wan" engines.
VIDEO_FREQUENCY=1

# Number of denoising steps for Wan video generation.
# Lower = faster but lower quality. Higher = slower but better quality.
#   10 = fast (default, good for Wan2.1)
#   20 = balanced
#   30 = high quality (slow on 30 GB RAM)
WAN_VIDEO_STEPS=40

# Frames per second for all video output (Wan2.1 generation + MoviePy composition).
# 16 = Wan2.1 native fps (no resampling, cleanest result).
# 24 = smoother playback (Wan2.1 resamples internally; increase WAN_VIDEO_FRAMES too).
# For 5 s video: 16 fps → 81 frames, 24 fps → 121 frames.
WAN_VIDEO_FPS=16

# Number of video frames for Wan2.1 generation (only used when ENABLE_VIDEO=WAN2.1).
# Must be 4k+1 (e.g. 49, 65, 81, 97, 121). At 16 fps: 81 ≈ 5s. At 24 fps: 121 ≈ 5s.
WAN_VIDEO_FRAMES=81

# ── Real-ESRGAN video upscaling (WAN2.1 only) ────────────────────────────────
# When true, the raw 480p WAN2.1 video is upscaled to 720p with Real-ESRGAN
# BEFORE the KTV subtitles and flag badge are composited — giving sharper,
# higher-detail results at no extra quality cost to the overlay.
# Requires one-time setup (see services/realesrgan_upscale.py).
ENABLE_REALESRGAN=true

# Path to the Real-ESRGAN repository root.
REALESRGAN_DIR=/home/y/Programming/Real-ESRGAN

# Model: RealESRGAN_x4plus (best general quality) or realesr-general-x4v3 (faster).
# The corresponding .pth file must exist in REALESRGAN_DIR/weights/.
REALESRGAN_MODEL=RealESRGAN_x4plus

# Scale factor: 1.5 × 480p = 720p. Use 2.0 for 960p (not needed for X/Twitter).
REALESRGAN_OUTSCALE=1.5

# Tile size for tiled inference — keeps VRAM low (fp16 is the default precision;
# add --fp32 in REALESRGAN_EXTRA_ARGS only if you need to force full precision).
REALESRGAN_TILE=256


# ── AI Models ─────────────────────────────────────────────────────────────────
# Values: "flagship" (grok-4)  |  "reasoning" (grok-4-1-fast)  |  "non-reasoning" (grok-4-1-fast-non-reasoning)
TWEET_MODEL=flagship              # tweet generation — best quality
TWEET_PICKER_MODEL=reasoning      # picking the best candidate
STRATEGY_MODEL=reasoning          # strategy analysis
WORD_PICK_MODEL=reasoning         # free-form word selection
TREND_FILTER_MODEL=non-reasoning  # trend keyword filtering
SIMILARITY_MODEL=non-reasoning    # duplicate / similarity check
VOICE_PICKER_MODEL=non-reasoning  # TTS voice selection


# ── Strategy & Analysis ───────────────────────────────────────────────────────
# Hours between X metrics refresh + LLM strategy re-analysis (same gate).
# Use false / off / never / disabled to turn OFF both metrics updates and strategy updates.
STRATEGY_UPDATE_INTERVAL_HOURS=false


# ── Self-Improvement Engine ───────────────────────────────────────────────────
ENABLE_SELF_IMPROVEMENT=false

# Run improvement every N cycles
IMPROVEMENT_INTERVAL_CYCLES=5

# Only run if avg engagement score is below this threshold (9999 = always run)
# IMPROVEMENT_SCORE_THRESHOLD=9999


# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Time between posts in seconds (18000 = 5 hours)
POST_INTERVAL_SECONDS=18000

# Stop the bot after this many consecutive failed cycles in a row.
# HTTP 401/402/403 from image providers (billing/auth) always stop immediately regardless.
# Set to 0 to disable the consecutive-failure limit.
MAX_CONSECUTIVE_FAILURES=2

# Check for updates on origin/main after each wait period.
# If new commits exist, the bot pulls them and restarts automatically.
# Set to false to disable.
AUTO_UPDATE=true


# ── Data & Logging ────────────────────────────────────────────────────────────
HISTORY_FILE=data/post_history.json
LOG_FILE=data/bot.log


# ── ComfyUI (test_comfyUI_WAN2.X.py scripts) ─────────────────────────────────
# Path to ComfyUI installation (where main.py lives — used in startup instructions).
COMFYUI_DIR=/home/y/Programming/ComfyUI
# Extra arguments passed to ComfyUI's main.py when auto-starting (see also README).
# Trade VRAM vs system RAM vs speed — verify names with: python main.py --help
#   --normalvram --fp16-vae  balanced
#   --lowvram [--fp16-vae]   offload more to system RAM; slower (active below)
#   --novram                 aggressive offload if your ComfyUI build supports it
# After changing COMFYUI_ARGS, restart ComfyUI (or let the bot restart it via shutdown).
# Low-VRAM modes do not guarantee huge resolutions on small GPUs — peak activation
# memory during sampling can still exceed available VRAM (e.g. 4K on 8 GB).
COMFYUI_ARGS=--lowvram --fp16-vae
# Seconds to wait for ComfyUI to become ready after auto-start (default 120).
COMFYUI_START_TIMEOUT=120

# Directory where ComfyUI saves output files.
# ComfyUI writes output relative to its working directory when launched, which
# may differ from COMFYUI_DIR.  Set this to wherever output/video/ actually appears.
COMFYUI_OUTPUT_DIR=/home/y/ComfyUI/output

# ComfyUI server URL (must be running before executing test scripts).
# Start it before running test scripts:
#   cd ~/ComfyUI && source venv/bin/activate && python main.py --lowvram --fp16-vae
COMFYUI_URL=http://127.0.0.1:8188
