AI_PROVIDER=grok

# Maximum tweet length in characters (280 for standard accounts, up to 25000 for Premium)
MAX_TWEET_LENGTH=500

POST_INTERVAL_SECONDS=18000
HISTORY_FILE=data/post_history.json
LOG_FILE=data/bot.log

VIDEO_STYLE=ktv
ANALYZE_LAST_N=10

USE_TRENDS=false
FUNNY_MODE=true

ENABLE_SELF_IMPROVEMENT=false
IMPROVEMENT_INTERVAL_CYCLES=5

FLAG_OVERLAY=true

ENABLE_GROK_VIDEO=false

# Generate a Grok Imagine video every Nth tweet (1 = every tweet, 2 = every 2nd, etc.)
GROK_VIDEO_FREQUENCY=1

# Model for strategy analysis: "reasoning" (grok-4-1-fast) or "non-reasoning" (grok-4-1-fast-non-reasoning)
STRATEGY_MODEL=reasoning

# Model for tweet generation: "flagship" (grok-4), "reasoning" (grok-4-1-fast), or "non-reasoning"
TWEET_MODEL=flagship

# Model for picking the best tweet candidate: "flagship" (default), "reasoning", or "non-reasoning"
TWEET_PICKER_MODEL=reasoning

# Model for filtering trend keywords: "non-reasoning" (default), "reasoning", or "flagship"
TREND_FILTER_MODEL=non-reasoning

# Model for free-form word selection when trends are off or yield nothing: "non-reasoning" (default), "reasoning", or "flagship"
WORD_PICK_MODEL=reasoning

# Model for semantic duplicate / similarity check: "non-reasoning" (default), "reasoning", or "flagship"
SIMILARITY_MODEL=non-reasoning

# Model for picking the best TTS voice for the tweet: "non-reasoning" (default), "reasoning", or "flagship"
VOICE_PICKER_MODEL=non-reasoning

# Hours between metric refreshes + strategy re-analysis (both steps share this interval)
STRATEGY_UPDATE_INTERVAL_HOURS=24

# Image style: "photographic" (default, realistic editorial) or "disney" (cute 3D Disney/Pixar CGI)
IMAGE_STYLE=disney

# Image generation provider: "midjourney" (default, uses TT_API_KEY) or "grok" (uses XAI_API_KEY)
IMAGE_PROVIDER=midjourney

# Number of images to request from Grok Imagine per generation (only used when IMAGE_PROVIDER=grok)
# GROK_IMAGE_COUNT=1

FLAG_OVERLAY=true