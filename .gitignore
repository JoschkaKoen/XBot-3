# Secrets — never commit API keys
.env

# Python cache & venv
__pycache__/
*.pyc
*.pyo
venv
venv/
env/
.venv/

# Runtime data (logs, checkpoints — large/binary, not tracked)
data/bot.log
data/improvement.log
data/checkpoints.sqlite*
data/test_cycle_output.json
data/test_cycle_terminal.txt
data/new_bot_branch.txt
# post_history.json IS tracked — it contains tweet history and engagement data

# Big media — images, video, audio
*.mp4
*.mov
*.avi
*.webm
*.wav
*.mp3
*.png

# Exceptions: keep folder placeholders and the background music track
!**/.gitkeep
!"Background Music/music.mp3"

# OS junk
.DS_Store
Thumbs.db