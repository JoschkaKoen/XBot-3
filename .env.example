# ============================================================
# German Learning X Bot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# AI Provider Switch: "grok" or "scaleway"
AI_PROVIDER=grok

# Grok / xAI
XAI_API_KEY=

# Scaleway AI
SCW_SECRET_KEY=
SCW_DEFAULT_PROJECT_ID=

# X / Twitter API
X_BEARER_TOKEN=

TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ElevenLabs TTS
ELEVENLABS_API_KEY=

# DeepL Translation
DEEPL_AUTH_KEY=

# Midjourney (via TTAPI.io)
TT_API_KEY=

# Bot Config
POST_INTERVAL_SECONDS=18000
HISTORY_FILE=data/post_history.json
LOG_FILE=data/bot.log

# Video style: "simple" or "ktv" (word-highlighting style)
VIDEO_STYLE=ktv

# Number of recent posts to review during self-improvement analysis
ANALYZE_LAST_N=10

# Word selection mode:
#   true  = pick word from real-time German trending topics (getdaytrends.com)
#   false = let the AI choose freely (default)
# Falls back to AI-chosen word automatically if no suitable trend is found.
USE_TRENDS=true

# Model used for strategy analysis (only applies when AI_PROVIDER=grok):
#   "reasoning"     = grok-4-1-fast        (deeper analysis, slightly slower)
#   "non-reasoning" = grok-4-1-fast-non-reasoning  (faster, lighter)
STRATEGY_MODEL=reasoning

# Model used for German example sentence generation (only applies when AI_PROVIDER=grok):
#   "flagship"      = grok-4                       (best language quality, ~$0.003/sentence)
#   "reasoning"     = grok-4-1-fast                (reasoning variant, same price as fast)
#   "non-reasoning" = grok-4-1-fast-non-reasoning  (default fast model)
SENTENCE_MODEL=flagship
