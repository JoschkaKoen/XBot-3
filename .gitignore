# Secrets — never commit API keys
.env
api-keys.env
*.local.env
.cursor-api-presets.json
# Public configuration (no keys) — tracked by git
!settings.env

# Python cache & venv
__pycache__/
*.pyc
*.pyo
venv
venv/
env/
.venv/

# Runtime data (logs, checkpoints — large/binary, not tracked)
data/bot.log
data/improvement.log
data/checkpoints.sqlite*
data/test_cycle_output.json
data/test_cycle_terminal.txt
data/new_bot_branch.txt

# Private / machine-specific runtime JSON (tweet URLs, strategy, voice cache — not for public repo)
data/post_history.json
data/strategy.json
data/strategy_history.json
data/metrics_refresh.json
data/video_state.json
data/voice_pool.json
data/scaffold_state.json

# Big media — images, video, audio
*.mp4
*.mov
*.avi
*.webm
*.wav
*.mp3
*.png

# Exceptions: keep folder placeholders and all Background Music assets
!**/.gitkeep
!"Background Music/*.mp3"
!"Background Music/*.wav"

# OS junk
.DS_Store
Thumbs.db
cursor switch model data
